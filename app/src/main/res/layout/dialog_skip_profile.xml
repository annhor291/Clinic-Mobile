<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bạn chưa hoàn thiện hồ sơ bệnh nhân"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Bạn vẫn có thể khám phá ứng dụng, nhưng cần bổ sung thông tin trước khi đặt lịch khám."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingMultiplier="1.4"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Bạn muốn làm gì?"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Nút Để sau -->
        <TextView
            android:id="@+id/btnLater"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Để sau"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:padding="8dp"/>

        <!-- Nút Hoàn thiện ngay — bo góc màu xanh đậm -->
        <TextView
            android:id="@+id/btnCompleteNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Hoàn thiện ngay"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_dark"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"/>

    </LinearLayout>

</LinearLayout>