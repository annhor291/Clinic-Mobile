<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/top_gradient_background"
        app:layout_constraintHeight_percent="0.38"
        app:layout_constraintTop_toTopOf="parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_booking_success"
            android:scaleType="centerInside"
            android:contentDescription="Đặt lịch thành công"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Đặt lịch thành công!"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chúng tôi sẽ xác nhận lịch hẹn của bạn sớm nhất"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Tự động về trang chủ sau 3 giây..."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnGoHome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="Về trang chủ ngay"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/primary_dark"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>